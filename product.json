{
  "name": "pegasusai",
  "version": "0.1.0",
  "productName": "PegasusAI",
  "description": "IDE PegasusAI - Offline-first AI-powered IDE based on Code-OSS",
  "author": "PegasusAI Team",
  "license": "MIT",
  "main": "out/main.js",
  "scripts": {
    "start": "electron .",
    "build": "gulp build",
    "watch": "gulp watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "package": "node scripts/build-pipeline.js",
    "rebrand": "node scripts/rebrand.js"
  },
  "dependencies": {
    "langchain": "^0.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.19.0",
    "gulp": "^4.0.2",
    "gulp-typescript": "^6.0.0-alpha.1",
    "jest": "^29.7.0",
    "playwright": "^1.40.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "ai.pegasus.ide",
    "productName": "PegasusAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "product.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icons/pegasus-256.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icons/pegasus-512.icns",
      "entitlements": "resources/entitlements.mac.plist"
    },
    "linux": {
      "target": ["deb", "rpm", "AppImage"],
      "icon": "resources/icons/pegasus-512.png",
      "category": "Development"
    }
  }
}
